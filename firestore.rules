// 꼬꼬의 귀가길 — Firestore 보안 규칙
// Firebase 콘솔 → Firestore Database → "규칙" 탭에 이 내용을 붙여넣고 "게시"하세요.
// (처음 만들 때 선택한 "테스트 모드"는 30일 뒤 만료되고 아무나 읽기/쓰기가 가능하므로
//  이벤트 전에 반드시 아래 규칙으로 교체하는 걸 권장합니다.)
//
// 컬렉션 구성
//  - scores   : 공개 순위표. 누구나 읽기 가능. 닉네임/점수만 저장(연락처 없음).
//  - contacts : 당첨자 연락처. 생성만 가능하고 "읽기 불가" → 개인정보 보호.
//               연락처 확인은 Firebase 콘솔(주최자)에서만 합니다.
//
// 공통 정책: 수정/삭제는 클라이언트에서 불가(정리는 콘솔에서 직접).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidScore() {
      let d = request.resource.data;
      return d.keys().hasOnly(['nickname', 'finished', 'elapsedMs', 'distance', 'rankScore', 'day', 'createdAt'])
        && d.nickname is string && d.nickname.size() >= 1 && d.nickname.size() <= 16
        && d.finished is bool
        && d.distance is number && d.distance >= 0 && d.distance <= 1650
        && d.elapsedMs is number && d.elapsedMs >= 0 && d.elapsedMs <= 60000
        && d.rankScore is number
        && d.day is string
        && d.createdAt == request.time;
    }

    function isValidContact() {
      let d = request.resource.data;
      return d.keys().hasOnly(['nickname', 'contact', 'rankScore', 'day', 'createdAt'])
        && d.nickname is string && d.nickname.size() >= 1 && d.nickname.size() <= 16
        && d.contact is string && d.contact.size() >= 1 && d.contact.size() <= 40
        && d.rankScore is number
        && d.day is string
        && d.createdAt == request.time;
    }

    // 이벤트 "당일에만" 등록을 받고 싶으면 아래 날짜를 행사일로 바꾼 뒤,
    // 각 create 규칙을 `... && isEventDay()` 로 교체하세요.
    // timestamp.date(연, 월, 일)은 UTC 자정 기준입니다.
    // 예) 한국시간(KST=UTC+9) 2026-06-28 하루만 받으려면 UTC 6/27 15:00 ~ 6/28 15:00 →
    //     아래처럼 6/27~6/29로 넉넉히 잡아도 됩니다.
    function isEventDay() {
      return request.time >= timestamp.date(2026, 6, 27)
        && request.time < timestamp.date(2026, 6, 29);
    }

    match /scores/{docId} {
      allow read: if true;
      allow create: if isValidScore();
      // 당일 제한을 켜려면 위 줄 대신: allow create: if isValidScore() && isEventDay();
      allow update, delete: if false;
    }

    match /contacts/{docId} {
      allow read: if false;        // 연락처는 콘솔에서만 열람 (공개 읽기 금지)
      allow create: if isValidContact();
      // 당일 제한을 켜려면: allow create: if isValidContact() && isEventDay();
      allow update, delete: if false;
    }
  }
}
